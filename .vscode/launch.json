    {
      "name": "Debug koogo",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/koogo/main.go",
      "env": {
        "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
